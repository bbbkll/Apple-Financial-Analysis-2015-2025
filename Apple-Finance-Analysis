   "source": [
    "# ACC102 Track 2 - Apple Inc. Real Financial Data Analysis (2015–2025)\n",
    "# Student: Keyu Gu | ID: 2469913\n",
    "# Data Source: Apple Investor Relations, Macrotrends\n",
    "# Access Date: 2026-04-22\n",
    "\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. Authentic publicly available financial data of Apple Inc.\n",
    "# Obtained from Apple's official annual reports. Unit: Billions of US Dollars\n",
    "data = {\n",
    "    \"Year\": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025],\n",
    "    \"Total Revenue\": [233.7, 215.6, 229.2, 265.6, 260.2, 274.5, 365.8, 394.3, 383.3, 391.0, 416.2],\n",
    "    \"Net Income\": [53.4, 45.7, 48.3, 59.5, 55.2, 57.4, 94.7, 100.6, 97.0, 93.7, 112.0]\n",
    "}\n",
    "\n",
    "# Convert to DataFrame\n",
    "df = pd.DataFrame(data)\n",
    "df.set_index(\"Year\", inplace=True)\n",
    "\n",
    "# 2. Data cleaning and calculation\n",
    "# calculate profit margin (authentic data)\n",
    "df[\"Profit Margin (%)\"] = (df[\"Net Income\"] / df[\"Total Revenue\"]) * 100\n",
    "\n",
    "# Print cleaned data\n",
    "print(\"=== Apple Inc. Financial Performance (2015–2025) ===\")\n",
    "print(\"Unit: Billions USD\")\n",
    "print(df.round(2))\n",
    "\n",
    "# 3. # Visualization 1: Trend of Total Revenue and Net Income\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.plot(df.index, df[\"Total Revenue\"], marker=\"o\", linewidth=2, label=\"Total Revenue\")\n",
    "plt.plot(df.index, df[\"Net Income\"], marker=\"s\", linewidth=2, label=\"Net Income\")\n",
    "plt.title(\"Apple Total Revenue & Net Income (2015–2025)\")\n",
    "plt.xlabel(\"Fiscal Year\")\n",
    "plt.ylabel(\"Billions USD\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 4. # Visualization 2: Change in Profit Margin\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.bar(df.index, df[\"Profit Margin (%)\"], color=\"#ff9900\")\n",
    "plt.title(\"Apple Net Profit Margin (2015–2025)\")\n",
    "plt.xlabel(\"Fiscal Year\")\n",
    "plt.ylabel(\"Profit Margin (%)\")\n",
    "plt.ylim(15, 30)\n",
    "plt.grid(True, axis=\"y\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 5. Key Insights\n",
    "print(\"\\n=== Key Insights ===\")\n",
    "print(\"1. Apple's revenue grew by 78% from 2015 to 2025, driven by strong iPhone and Services segments.\")\n",
    "print(\"2. Net income increased by 110% over the decade, outpacing revenue growth.\")\n",
    "print(\"3. Profit margin remained stable at 20-28%, reflecting strong operational efficiency and pricing power.\")\n",
    "print(\"4. The highest growth occurred in 2021, when revenue rose 33% year-over-year.\")"
